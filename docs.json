{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "PuntHub Knowledge Center",
  "colors": {
    "primary": "#0f00ad",
    "light": "#ffffff",
    "dark": "#000000"
  },
  "favicon": "/images/punthublogo-1.PNG",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://mintlify.com/blog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "verification"
            ]
          },
          {
            "group": "Affiliate Program",
            "icon": "money-bills",
            "tag": "New",
            "pages": [
              "essentials/settings",
              "affiliates/requirements"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "Whitepaper 2026/27",
        "icon": "boxes-stacked",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/logoblacktransparent.png",
    "dark": "/images/logoblacktransparent.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:help@punthub.fun"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/punthub.fun",
      "linkedin": "https://linkedin.com/company/mintlify",
      "medium": "https://gravitas.medium.com",
      "facebook": "https://facebook.com/punthub.fun"
    },
    "links": [
      {
        "header": "Quick Links",
        "items": [
          {
            "label": "Company Profile",
            "href": "/about"
          },
          {
            "label": "Whitepaper 2026/27",
            "href": "/whitepaper"
          },
          {
            "label": "Affiliate Program",
            "href": "/affiliates"
          },
          {
            "label": "Feedback/Reports",
            "href": "/contact"
          }
        ]
      },
      {
        "header": "Legal Stuff",
        "items": [
          {
            "label": "Terms",
            "href": "/terms"
          },
          {
            "label": "Privacy",
            "href": "/privacy"
          },
          {
            "label": "Refunds",
            "href": "/refunds"
          },
          {
            "label": "Cookies",
            "href": "/cookies"
          },
          {
            "label": "Disclaimer",
            "href": "/disclaimer"
          }
        ]
      }
    ]
  },
  "background": {
    "decoration": "gradient"
  },
  "appearance": {
    "strict": false,
    "default": "light"
  },
  "fonts": {
    "family": "Poppins",
    "weight": 700,
    "body": {
      "weight": 500
    }
  },
  "banner": {
    "content": "Need help? Drop us an email at help@punthub.fun",
    "dismissible": true
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  },
  "errors": {
    "404": {
      "title": "Page not found ",
      "description": "The page you are looking for doesn’t exist or has been moved."
    }
  },
  "search": {
    "prompt": "How can I help you?"
  },
  "description": "Useful resources and documentation for all things related to the PuntHub platform"
}
